APP_ENV=local
APP_PORT=4000
FALLBACK_LANGUAGE=en
APP_LOCATE_LANGUAGE=x-lang
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
API_PREFIX=api
API_VERSION=1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# For Docker: DATABASE_HOST=database, DATABASE_PORT=5432
# For Local: DATABASE_HOST=localhost, DATABASE_PORT=5432
# For Docker with port mapping: DATABASE_PORT_EXTERNAL=5440 (avoids conflicts)
DATABASE_DRIVER=postgres
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_PORT_EXTERNAL=5440
DATABASE_NAME=postgres
DATABASE_USER=postgres_user
DATABASE_PASSWORD=secret
DATABASE_SYNCHRONIZE=false
DATABASE_AUTOLOAD=false

# Connecting from host machine to Docker database:
# Host: localhost, Port: 5440 (not 5432!)

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# WARNING: Change these secrets in production!
# Generate strong secrets with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-development-access-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-development-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# For Docker: REDIS_HOST=redis, REDIS_PORT=6379
# For Local: REDIS_HOST=localhost, REDIS_PORT=6379
# For Docker with port mapping: REDIS_PORT_EXTERNAL=6400 (avoids conflicts)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6400
REDIS_PASSWORD=redispass
REDIS_TTL=3600

# Connecting from host machine to Docker Redis:
# Host: localhost, Port: 6400 (not 6379!)

# ============================================================================
# QUEUE CONFIGURATION (uses Redis)
# ============================================================================
QUEUE_HOST=redis
QUEUE_PORT=6379
QUEUE_PASSWORD=redispass

# ============================================================================
# LOCALSTACK (for S3 mocking in development)
# ============================================================================
LOCALSTACK_PORT=4566

# ============================================================================
# PORT MAPPING SUMMARY FOR DOCKER DEVELOPMENT
# ============================================================================
#
# Service          | Container Port | Host Port | Connect From App | Connect From Host
# ---------------- | -------------- | --------- | ---------------- | -----------------
# API              | 4000           | 4000      | N/A              | localhost:4000
# PostgreSQL       | 5432           | 5440      | database:5432    | localhost:5440
# Redis            | 6379           | 6400      | redis:6379       | localhost:6400
# LocalStack (S3)  | 4566           | 4566      | localstack:4566  | localhost:4566
#
# This avoids conflicts with services running on your local machine!
#
# If running WITHOUT Docker (local development):
# - Set DATABASE_HOST=localhost and DATABASE_PORT=5432
# - Set REDIS_HOST=localhost and REDIS_PORT=6379
# - DATABASE_PORT_EXTERNAL and REDIS_PORT_EXTERNAL are not used