# Production Environment Configuration
# Copy this file to .env for production deployments

APP_ENV=production
APP_PORT=4000
FALLBACK_LANGUAGE=en
APP_LOCATE_LANGUAGE=x-lang
CORS_ORIGIN=https://your-production-domain.com
API_PREFIX=api
API_VERSION=1

# ============================================================================
# DATABASE CONFIGURATION (Production)
# ============================================================================
# Use managed database service (RDS, Cloud SQL, etc.) in production
# DO NOT use containerized databases for production!
DATABASE_DRIVER=postgres
DATABASE_HOST=your-production-db-host.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=your_production_db
DATABASE_USER=your_production_user
DATABASE_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD
DATABASE_SYNCHRONIZE=false
DATABASE_AUTOLOAD=false

# NOTE: DATABASE_PORT_EXTERNAL is only used for Docker port mapping
# Not needed in production when using managed database services

# ============================================================================
# JWT CONFIGURATION (Production)
# ============================================================================
# CRITICAL: Generate strong random secrets!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# DO NOT use the example values below!
JWT_ACCESS_SECRET=CHANGE-THIS-GENERATE-64-BYTE-RANDOM-SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE-THIS-GENERATE-DIFFERENT-64-BYTE-RANDOM-SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# REDIS CONFIGURATION (Production)
# ============================================================================
# Use managed Redis service (ElastiCache, Cloud Memorystore, etc.)
REDIS_HOST=your-production-redis-host.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD
REDIS_TTL=3600

# NOTE: REDIS_PORT_EXTERNAL is only used for Docker port mapping
# Not needed in production when using managed Redis services

# ============================================================================
# QUEUE CONFIGURATION (Production)
# ============================================================================
# Typically uses the same Redis instance as cache
QUEUE_HOST=your-production-redis-host.cache.amazonaws.com
QUEUE_PORT=6379
QUEUE_PASSWORD=CHANGE-THIS-TO-STRONG-PASSWORD

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
# ✅ APP_ENV is set to 'production'
# ✅ DATABASE_SYNCHRONIZE is set to 'false' (use migrations!)
# ✅ JWT secrets are strong random values (64+ bytes)
# ✅ Database password is strong and unique
# ✅ Redis password is strong and unique
# ✅ CORS_ORIGIN is set to your actual production domain(s)
# ✅ All database and Redis hosts point to managed services
# ✅ SSL/TLS is enabled for database and Redis connections
# ✅ Environment variables are injected securely (not committed to git!)
# ✅ Migrations are run before deployment
# ✅ Health checks are configured
# ✅ Monitoring and logging are set up
